PORT=5000
CLIENT_ORIGIN=http://localhost:5173

# Local PostgreSQL
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=eswasthya

# Single URL alternative used by many deployment providers.
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DATABASE

# AWS RDS mode. Set USE_AWS=true to make the app and Knex use these values.
USE_AWS=false
AWS_RDS_HOST=
AWS_RDS_PORT=5432
AWS_RDS_USER=
AWS_RDS_PASSWORD=
AWS_RDS_DATABASE=

# Optional SSL override for hosted PostgreSQL.
# Use true or require when your provider requires TLS.
PGSSL=
DB_SSL=

# AWS S3 uploads
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Auth/session
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Mail
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# LLM / chatbot
GROQ_API_KEY=
GOOGLE_API_KEY=
COHERE_API_KEY=

# Redis
REDIS_URL=
