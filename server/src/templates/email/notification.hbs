<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{title}}</title>
  </head>
  <body style="margin:0;padding:0;background:#f1f7f6;font-family:'Segoe UI',Arial,sans-serif;color:#0f172a;">
    <table role="presentation" cellspacing="0" cellpadding="0" width="100%" style="background:#f1f7f6;padding:32px 12px;">
      <tr>
        <td align="center">
          <table role="presentation" cellspacing="0" cellpadding="0" width="100%" style="max-width:640px;">
            <tr>
              <td style="padding:0 0 14px 0;text-align:center;">
                <span style="display:inline-block;padding:7px 14px;border-radius:999px;background:#dbeafe;color:#1d4ed8;font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;">
                  Account notification
                </span>
              </td>
            </tr>
            <tr>
              <td style="background:#0f172a;padding:28px 32px 24px 32px;border-radius:24px 24px 0 0;">
                <p style="margin:0 0 10px 0;font-size:13px;font-weight:700;letter-spacing:0.6px;text-transform:uppercase;color:#93c5fd;">
                  {{appName}}
                </p>
                <h1 style="margin:0;font-size:30px;line-height:1.25;color:#ffffff;">
                  {{title}}
                </h1>
                <p style="margin:12px 0 0 0;font-size:15px;line-height:1.7;color:#cbd5e1;">
                  Important information from your health account.
                </p>
              </td>
            </tr>
            <tr>
              <td style="background:#ffffff;padding:32px;border:1px solid #d9e6e3;border-top:none;border-radius:0 0 24px 24px;box-shadow:0 18px 42px rgba(15,23,42,0.08);">
                <p style="margin:0 0 14px 0;font-size:15px;line-height:1.7;color:#334155;">Hi {{recipientName}},</p>
                <p style="margin:0 0 24px 0;font-size:15px;line-height:1.8;color:#475569;">
                  {{message}}
                </p>
                {{#if actionUrl}}
                  <table role="presentation" cellspacing="0" cellpadding="0" style="margin:0 0 24px 0;">
                    <tr>
                      <td style="border-radius:14px;background:#0f766e;">
                        <a
                          href="{{actionUrl}}"
                          style="display:inline-block;padding:14px 22px;color:#ffffff;text-decoration:none;font-size:14px;font-weight:700;"
                        >
                          {{#if actionText}}{{actionText}}{{else}}View details{{/if}}
                        </a>
                      </td>
                    </tr>
                  </table>
                {{else}}
                  <table role="presentation" cellspacing="0" cellpadding="0" width="100%" style="margin:0 0 24px 0;">
                    <tr>
                      <td style="padding:18px 20px;border-radius:18px;background:#f8fafc;border:1px solid #e2e8f0;">
                        <p style="margin:0;font-size:14px;line-height:1.7;color:#475569;">
                          Sign in to your {{appName}} dashboard to review the latest update and take action if needed.
                        </p>
                      </td>
                    </tr>
                  </table>
                {{/if}}
                <table role="presentation" cellspacing="0" cellpadding="0" width="100%">
                  <tr>
                    <td style="padding:18px 20px;border-radius:18px;background:#eff6ff;border:1px solid #bfdbfe;">
                      <p style="margin:0 0 6px 0;font-size:13px;font-weight:700;letter-spacing:0.6px;text-transform:uppercase;color:#1d4ed8;">
                        Why you received this
                      </p>
                      <p style="margin:0;font-size:14px;line-height:1.7;color:#334155;">
                        This email was sent because there was activity related to your {{appName}} account.
                      </p>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
            <tr>
              <td style="padding:18px 8px 0 8px;text-align:center;">
                <p style="margin:0;font-size:12px;color:#64748b;">
                  This is an automated notification from {{appName}}. &copy; {{year}}
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
